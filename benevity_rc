# configure ssh-agent
function aws-ssh-agent-update() {
  if $ENABLE_SSH_KEY_MANAGEMENT; then
    local -a AWS_PEMS
    AWS_PEMS=()

    case $1 in
      benevity_live_prod)
        AWS_PEMS+=("${SSH_KEY_DIR}bastion.benevity-live.org")
        ;;
      benevity_live_dr)
        AWS_PEMS+=("${SSH_KEY_DIR}bastion.benevity-live-dr.org")
        ;;
      benevity_live_preprod|benevity_preprod_prodsupport)
        AWS_PEMS+=("${SSH_KEY_DIR}bastion.benevity-preprod.org")
        ;;
      benevity_live_staging|benevity_staging_uat)
        AWS_PEMS+=("${SSH_KEY_DIR}bastion.benevity-staging.org")
        ;;
      benevity_shared_prod|benevity_shared_qa)
        AWS_PEMS+=("${SSH_KEY_DIR}bastion.benevity-shared.org")
        ;;
      benevity_sre_qa)
        AWS_PEMS+=("${SSH_KEY_DIR}bastion.benevity-sre-qa.org")
        ;;
      benevity_prod_versaic|benevity_prodtest_versaic|benevity_shared_versaic)
        AWS_PEMS+=("${SSH_KEY_DIR}bastion.benevity-prod-versaic.org")
        ;;
      benevity_mgmt_security)
        AWS_PEMS+=("${SSH_KEY_DIR}bastion.benevity-security.org")
        ;;
    esac

    # Keep all available Benevity bastion keys loaded so cross-account host hops work.
    local pem
    for pem in "${SSH_KEY_DIR}"bastion.benevity-*.org; do
      [[ -f "$pem" ]] && AWS_PEMS+=("$pem")
    done

    eval $(ssh-agent) >/dev/null 2>&1
    ssh-add -D >/dev/null 2>&1
    local seen=""
    for pem in "${AWS_PEMS[@]}"; do
      [[ -f "$pem" ]] || continue
      [[ "$seen" == *"|$pem|"* ]] && continue
      ssh-add "$pem" >/dev/null 2>&1
      seen="${seen}|${pem}|"
    done
  fi
}

# start an ssm session ("ash i-0a503e0c181c888f0")
function ash() {
  aws ssm start-session --target $1
}

# List running bastion instances in the active AWS profile.
function aws-bastions() {
  aws ec2 describe-instances \
    --filters "Name=instance-state-name,Values=running" "Name=tag:Name,Values=*bastion*" \
    --query "Reservations[].Instances[].{Id:InstanceId,Ip:PrivateIpAddress,Name:Tags[?Key=='Name'].Value|[0],State:State.Name}|sort_by(@,&Name)[]" \
    --output table
}

# Start an SSM session to the first running bastion in the active AWS profile.
function ash-bastion() {
  local instance_id
  instance_id=$(
    aws ec2 describe-instances \
      --filters "Name=instance-state-name,Values=running" "Name=tag:Name,Values=*bastion*" \
      --query "Reservations[].Instances[].InstanceId | [0]" \
      --output text
  )

  if [[ -z "$instance_id" || "$instance_id" == "None" ]]; then
    echo "No running bastion found in AWS profile '${AWS_PROFILE:-unset}'" >&2
    return 1
  fi

  echo "Starting SSM session to $instance_id in AWS profile '${AWS_PROFILE:-unset}'"
  ash "$instance_id"
}

function aws-auth() {
  if [[ -z "$1" ]]; then
    unset AWS_DEFAULT_PROFILE AWS_PROFILE AWS_EB_PROFILE
    echo AWS profile cleared.
    return
  fi

  local -a available_profiles
  available_profiles=($(aws_profiles))

  case $SHELL in
    /bin/bash)
      if [[ ! "${available_profiles[@]}" =~ " $1 " ]]; then
        echo "Profile '$1' not found in '${AWS_CONFIG_FILE:-$HOME/.aws/config}'" >&2
        echo "Available profiles: '${available_profiles[@]:-no profiles found}'" >&2
        return 1
      fi
      ;;
    /bin/zsh)
      if [[ -z "${available_profiles[(r)$1]}" ]]; then
        echo "${fg[red]}Profile '$1' not found in '${AWS_CONFIG_FILE:-$HOME/.aws/config}'" >&2
        echo "Available profiles: ${(j:, :)available_profiles:-no profiles found}${reset_color}" >&2
        return 1
      fi
      ;;
  esac

  export AWS_DEFAULT_PROFILE="$1"
  export AWS_PROFILE="$1"
  export AWS_EB_PROFILE="$1"
  aws sso login && \
    awssso && \
    set_colors "$1" && \
    aws-whoami && \
    aws-ssh-agent-update "$1"
}

function aws_profiles() {
  [[ -r "${AWS_CONFIG_FILE:-$HOME/.aws/config}" ]] || return 1
  grep --color=never -Eo '\[.*\]' "${AWS_CONFIG_FILE:-$HOME/.aws/config}" | sed -E 's/^[[:space:]]*\[(profile)?[[:space:]]*([-_[:alnum:]\.@]+)\][[:space:]]*$/\2/g'
}

function _aws_profiles() {
  case $SHELL in
    /bin/bash)
      local word="${COMP_WORDS[COMP_CWORD]}"
      COMPREPLY=($(compgen -W "$(aws_profiles)" -- "$word"))
      ;;
    /bin/zsh)
      local -a profiles
      profiles=($(aws_profiles))
      _describe 'aws profile' profiles
      ;;
  esac
}

# tab-completion for aws profile names
case $SHELL in
  /bin/bash)
    complete -F _aws_profiles aws-auth
    complete -F _aws_profiles asp
    ;;
  /bin/zsh)
    autoload -Uz compinit
    if [[ -z "${_comps[aws-auth]:-}" ]]; then
      compinit
    fi
    compdef _aws_profiles aws-auth
    compdef _aws_profiles asp
    ;;
  *)
    echo "aws profile tab-completion not available for $SHELL"
    ;;
esac

function asp () {
	if [[ -z "$1" ]]
	then
		unset AWS_DEFAULT_PROFILE AWS_PROFILE AWS_EB_PROFILE
		echo AWS profile cleared.
		return
	fi
	local -a available_profiles
	available_profiles=($(aws_profiles))
	if [[ -z "${available_profiles[(r)$1]}" ]]
	then
		echo "${fg[red]}Profile '$1' not found in '${AWS_CONFIG_FILE:-$HOME/.aws/config}'" >&2
		echo "Available profiles: ${(j:, :)available_profiles:-no profiles found}${reset_color}" >&2
		return 1
	fi
	export AWS_DEFAULT_PROFILE=$1
	export AWS_PROFILE=$1
	export AWS_EB_PROFILE=$1
	aws-ssh-agent-update "$1"
}


