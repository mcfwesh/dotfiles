function encrypt_string() {
  if [[ -z "$1" ]]; then
    echo "Usage: encrypt_string <string>"
    return 1
  fi
  aws kms encrypt --key-id alias/ssm --output text --query CiphertextBlob --cli-binary-format raw-in-base64-out --plaintext fileb://<( echo -n "$1")
}

function decrypt_string() {
  if [[ -z "$1" ]]; then
    echo "Usage: decrypt_string <base64-encoded-ciphertext>"
    return 1
  fi
  aws kms decrypt --ciphertext-blob fileb://<(echo -n "$1" | base64 --decode) --output text --query Plaintext --cli-binary-format raw-in-base64-out | base64 --decode
}

function gcp_encrypt_cockroach_string() {
  if [[ -z "$1" ]]; then
    echo "Usage: gcp_encrypt_cockroach_string <string>"
    return 1
  fi
  if [[ -z "$2" ]]; then
    echo "Usage: gcp_encrypt_cockroach_string <string> <gcp-project-id>"
    return 1
  fi
  echo -n "$1" | gcloud kms encrypt --key cockroachdb-key --keyring=cockroachdb-keyring --location=us-east4 --plaintext-file=- --ciphertext-file=- --project="$2" | base64
}

function gcp_decrypt_cockroach_string() {
  if [[ -z "$1" ]]; then
    echo "Usage: gcp_decrypt_cockroach_string <base64-encoded-ciphertext>"
    return 1
  fi
  if [[ -z "$2" ]]; then
    echo "Usage: gcp_decrypt_cockroach_string <base64-encoded-ciphertext> <gcp-project-id>"
    return 1
  fi
  echo -n "$1" | base64 --decode | gcloud kms decrypt --key cockroachdb-key --keyring=cockroachdb-keyring --location=us-east4 --ciphertext-file=- --plaintext-file=- --project="$2"
}

