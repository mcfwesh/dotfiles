# ============================================

# Recursive text extractor for Atlassian Document Format
JQ_EXTRACT=$'
  def extract_text:
    if type == "object" then
      if .type == "text" then .text
      elif .type == "hardBreak" then "\\\\n"
      elif .content then (.content | map(extract_text) | join(""))
      else ""
      end
    elif type == "array" then
      map(extract_text) | join("")
    else ""
    end;
'

JIRA_AUTH="${ATLASSIAN_USER_EMAIL}:${JIRA_API_TOKEN:-$ATLASSIAN_API_TOKEN}"

# ============================================
# 1. SEARCH BY KEYWORD
# ============================================
jira-search() {
  if [ -z "$1" ]; then
    echo "Usage: jira-search <keyword>"
    return 1
  fi

  curl -s -X POST \
    "https://benevity.atlassian.net/rest/api/3/search/jql" \
    -u "$JIRA_AUTH" \
    -H "Content-Type: application/json" \
    -d "{
      \"jql\": \"assignee = currentUser() AND text ~ \\\"$1\\\" ORDER BY status DESC, updated DESC\",
      \"maxResults\": 50,
      \"fields\": [\"key\", \"summary\", \"status\", \"description\"]
    }" | jq -r "${JQ_EXTRACT}"'
      .issues[] |
      "==============================================",
      "[\(.key)] \(.fields.summary)",
      "STATUS: \(.fields.status.name)",
      "",
      "DESCRIPTION:",
      (if .fields.description then (.fields.description.content | map(extract_text) | join("\n")) else "No description" end),
      ""
    '
}

# ============================================
# 2. CURRENT SPRINT TASKS (excludes DEVOPS-2833 epic)
# ============================================
jira-sprint() {
  local EPIC="DEVOPS-2833"

  # Get stories under the epic
  local STORIES=$(curl -s -X POST \
    "https://benevity.atlassian.net/rest/api/3/search/jql" \
    -u "$JIRA_AUTH" \
    -H "Content-Type: application/json" \
    -d "{\"jql\": \"\\\"Epic Link\\\" = ${EPIC} OR parent = ${EPIC}\", \"maxResults\": 200, \"fields\": [\"key\"]}" \
    | jq -r '.issues[].key' | tr '\n' ',' | sed 's/,$//')

  # Get subtasks of those stories
  local SUBTASKS=$(curl -s -X POST \
    "https://benevity.atlassian.net/rest/api/3/search/jql" \
    -u "$JIRA_AUTH" \
    -H "Content-Type: application/json" \
    -d "{\"jql\": \"parent IN (${STORIES})\", \"maxResults\": 200, \"fields\": [\"key\"]}" \
    | jq -r '.issues[].key' | tr '\n' ',' | sed 's/,$//')

  # Build exclusion list
  local EXCLUDE="${EPIC},${STORIES},${SUBTASKS}"

  # Get sprint tickets with full descriptions
  curl -s -X POST \
    "https://benevity.atlassian.net/rest/api/3/search/jql" \
    -u "$JIRA_AUTH" \
    -H "Content-Type: application/json" \
    -d "{
      \"jql\": \"assignee = currentUser() AND sprint in openSprints() AND key NOT IN (${EXCLUDE}) ORDER BY status DESC, updated DESC\",
      \"maxResults\": 100,
      \"fields\": [\"key\", \"summary\", \"status\", \"description\"]
    }" | jq -r "${JQ_EXTRACT}"'
      .issues[] |
      "==============================================",
      "[\(.key)] \(.fields.summary)",
      "STATUS: \(.fields.status.name)",
      "",
      "DESCRIPTION:",
      (if .fields.description then (.fields.description.content | map(extract_text) | join("\n")) else "No description" end),
      ""
    '
}

# ============================================
# 3. ALL TICKETS EVER ASSIGNED
# ============================================
jira-all() {
  curl -s -X POST \
    "https://benevity.atlassian.net/rest/api/3/search/jql" \
    -u "$JIRA_AUTH" \
    -H "Content-Type: application/json" \
    -d '{
      "jql": "assignee = currentUser() ORDER BY status DESC, updated DESC",
      "maxResults": 100,
      "fields": ["key", "summary", "status", "description"]
    }' | jq -r "${JQ_EXTRACT}"'
      .issues[] |
      "==============================================",
      "[\(.key)] \(.fields.summary)",
      "STATUS: \(.fields.status.name)",
      "",
      "DESCRIPTION:",
      (if .fields.description then (.fields.description.content | map(extract_text) | join("\n")) else "No description" end),
      ""
    '
}

# ============================================
# 4. GET TICKET BY KEY (with Epic children)
# ============================================
jira-ticket() {
  if [ -z "$1" ]; then
    echo "Usage: jira-ticket <TICKET-KEY>"
    return 1
  fi

  local TICKET="$1"

  # Get ticket info - sanitize control characters before jq
  local RESULT=$(curl -s -X GET \
    "https://benevity.atlassian.net/rest/api/3/issue/${TICKET}?fields=key,summary,description,issuetype,status" \
    -u "$JIRA_AUTH" \
    -H "Accept: application/json" | tr -d '\000-\011\013\014\016-\037')

  local ISSUE_TYPE=$(printf '%s' "$RESULT" | jq -r '.fields.issuetype.name')

  echo ""
  printf '%s' "$RESULT" | jq -r "${JQ_EXTRACT}"'
    "==============================================",
    "\(.key) [\(.fields.issuetype.name)]",
    "==============================================",
    "",
    "TITLE: \(.fields.summary)",
    "STATUS: \(.fields.status.name)",
    "",
    "DESCRIPTION:",
    (if .fields.description then (.fields.description.content | map(extract_text) | join("\n")) else "No description" end),
    ""
  '

  # If Epic, get children
  if [ "$ISSUE_TYPE" = "Epic" ]; then
    echo ""
    echo "=============================================="
    echo "STORIES UNDER THIS EPIC"
    echo "=============================================="

    curl -s -X POST \
      "https://benevity.atlassian.net/rest/api/3/search/jql" \
      -u "$JIRA_AUTH" \
      -H "Content-Type: application/json" \
      -d "{\"jql\": \"\\\"Epic Link\\\" = ${TICKET}\", \"maxResults\": 100, \"fields\": [\"key\", \"summary\", \"status\", \"description\"]}" \
      | tr -d '\000-\011\013\014\016-\037' \
      | jq -r "${JQ_EXTRACT}"'
        .issues[] |
        "----------------------------------------------",
        "[\(.key)] \(.fields.summary)",
        "STATUS: \(.fields.status.name)",
        "",
        "DESCRIPTION:",
        (if .fields.description then (.fields.description.content | map(extract_text) | join("\n")) else "No description" end),
        ""
      '
  fi
}

# ============================================
# 5. GET JUST TICKET KEYS (for piping)
# ============================================
jira-keys() {
  if [ -z "$1" ]; then
    echo "Usage: jira-keys <keyword>"
    return 1
  fi

  curl -s -X POST \
    "https://benevity.atlassian.net/rest/api/3/search/jql" \
    -u "$JIRA_AUTH" \
    -H "Content-Type: application/json" \
    -d "{
      \"jql\": \"assignee = currentUser() AND text ~ \\\"$1\\\" ORDER BY status DESC, updated DESC\",
      \"maxResults\": 50,
      \"fields\": [\"key\"]
    }" | jq -r '.issues[].key'
}

