#!/usr/bin/env zsh
# Re-apply local overrides to upstream-managed skills after npx skills update.
# The DISABLE_AUTO_INVOKE array is the single source of truth:
#   - listed  → disable-model-invocation: true is ensured
#   - unlisted → disable-model-invocation: true is removed
# Edit this list freely — add/remove skill names as your needs change.

AGENTS_DIR="${HOME:-/Users/nathan.ojieabu}/.agents"
SKILLS_DIR="$AGENTS_DIR/skills"

# Skills to suppress from auto-invocation.
# Kept installed for manual use but won't bloat context automatically.
DISABLE_AUTO_INVOKE=(
  edit-article
  writing-beats
  writing-fragments
  writing-shape
  migrate-to-shoehorn
  scaffold-exercises
  ubiquitous-language
  teach
  obsidian-vault
  setup-matt-pocock-skills
  request-refactor-plan
  improve-codebase-architecture
  tdd
)

add_flag() {
  local file="$1"
  if grep -q '^disable-model-invocation:' "$file"; then
    return 0
  fi
  local tmp=$(mktemp)
  awk 'NR==1{print; print "disable-model-invocation: true"; next}1' "$file" > "$tmp"
  mv "$tmp" "$file"
  echo "agents-patch-skills: + $(basename $(dirname $file))"
}

remove_flag() {
  local file="$1"
  if ! grep -q '^disable-model-invocation:' "$file"; then
    return 0
  fi
  local tmp=$(mktemp)
  grep -v '^disable-model-invocation:' "$file" > "$tmp"
  mv "$tmp" "$file"
  echo "agents-patch-skills: - $(basename $(dirname $file))"
}

in_disable_list() {
  local skill="$1"
  for s in "${DISABLE_AUTO_INVOKE[@]}"; do
    [[ "$s" == "$skill" ]] && return 0
  done
  return 1
}

for skill_dir in "$SKILLS_DIR"/*/; do
  skill=$(basename "$skill_dir")
  file="$skill_dir/SKILL.md"
  [[ -f "$file" ]] || continue

  if in_disable_list "$skill"; then
    add_flag "$file"
  else
    remove_flag "$file"
  fi
done

echo "agents-patch-skills: done"
