#!/usr/bin/env zsh
# Pull latest global skills (npx skills), then push ~/.agents to mcfwesh/agents-config
set -e

AGENTS_DIR="${HOME:-/Users/nathan.ojieabu}/.agents"
SKILLS_DIR="$AGENTS_DIR/skills"
export PATH="/opt/homebrew/bin:/usr/local/bin:${PATH}"

cd "$AGENTS_DIR"

# Snapshot which skills have disable-model-invocation: true before updating.
# This preserves any flag you've set manually — no list to maintain.
typeset -a suppressed=()
for skill_dir in "$SKILLS_DIR"/*/; do
  file="$skill_dir/SKILL.md"
  [[ -f "$file" ]] && grep -q '^disable-model-invocation:' "$file" \
    && suppressed+=($(basename "$skill_dir"))
done

echo "agents-sync: checking for skill updates (npx skills update -g -y)..."
if ! npx skills update -g -y; then
  echo "agents-sync: skill update failed" >&2
  exit 1
fi

# Restore flags wiped by upstream updates.
for skill in "${suppressed[@]}"; do
  file="$SKILLS_DIR/$skill/SKILL.md"
  [[ -f "$file" ]] || continue
  if ! grep -q '^disable-model-invocation:' "$file"; then
    tmp=$(mktemp)
    awk 'NR==1{print; print "disable-model-invocation: true"; next}1' "$file" > "$tmp"
    mv "$tmp" "$file"
    echo "agents-sync: restored disable-model-invocation on $skill"
  fi
done

if [[ -z $(git status --porcelain) ]]; then
  echo "agents-sync: nothing changed, already up to date."
  exit 0
fi

echo "agents-sync: staging changes..."
git add -A

CHANGED=$(git diff --cached --stat | tail -1)
git commit -m "chore: sync agents — $(date '+%Y-%m-%d %H:%M')"
echo "agents-sync: committed ($CHANGED)"

git push origin main
echo "agents-sync: pushed to mcfwesh/agents-config ✓"
