#!/bin/sh
# Secrets are intentionally NOT synced. After Download on a new machine, restore:
#   ~/.cursor/mcp-env-vars
#   ~/.secrets (if used)
# Then reload Cursor (Cmd+Shift+P -> Developer: Reload Window).

cat <<'EOF'
Cursor sync does not include secret files.

Restore manually on this machine:
  1. ~/.cursor/mcp-env-vars
  2. Re-authenticate MCP servers that use OAuth (e.g. JFrog)
  3. Run: cursor-mcp-env-sync  (if configured in ~/.zshrc)

Then reload Cursor.
EOF
