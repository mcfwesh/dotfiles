#!/usr/bin/env zsh
# Refresh Brewfile when Homebrew inventory changes, then push dotfiles.
set -e

REPO="${HOME}/external-repos/dotfiles"
BREWFILE="${REPO}/Brewfile"
export PATH="/opt/homebrew/bin:/usr/local/bin:${PATH}"

cd "${REPO}"

if command -v brew >/dev/null 2>&1; then
  TMP_BREWFILE=$(mktemp)
  trap 'rm -f "$TMP_BREWFILE"' EXIT

  brew bundle dump --file="$TMP_BREWFILE" --force >/dev/null

  if [[ ! -f "$BREWFILE" ]]; then
    mv "$TMP_BREWFILE" "$BREWFILE"
    echo "dotfiles-sync: created Brewfile from Homebrew inventory."
  elif ! cmp -s "$TMP_BREWFILE" "$BREWFILE"; then
    mv "$TMP_BREWFILE" "$BREWFILE"
    echo "dotfiles-sync: refreshed Brewfile from Homebrew inventory."
  else
    rm -f "$TMP_BREWFILE"
    echo "dotfiles-sync: Brewfile already matches Homebrew inventory."
  fi
fi

if [[ -z $(git status --porcelain) ]]; then
  echo "dotfiles-sync: nothing changed, already up to date."
  exit 0
fi

echo "dotfiles-sync: staging changes..."
git add -A

CHANGED=$(git diff --cached --stat | tail -1)
git commit -m "chore: sync dotfiles — $(date '+%Y-%m-%d %H:%M')"
echo "dotfiles-sync: committed (${CHANGED})"

git push origin main
echo "dotfiles-sync: pushed to mcfwesh/dotfiles ✓"
