<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.nathan.agents-sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>/Users/nathan.ojieabu/.local/bin/agents-sync</string>
  </array>

  <!-- Run every 30 minutes -->
  <key>StartInterval</key>
  <integer>1800</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/nathan.ojieabu/Library/Logs/agents-sync.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/nathan.ojieabu/Library/Logs/agents-sync.err.log</string>
</dict>
</plist>
